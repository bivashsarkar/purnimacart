# ===== Firebase =====
# Get these from Firebase Console -> Project Settings -> General -> Your apps -> Web app
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="000000000000"
VITE_FIREBASE_APP_ID="1:000000000000:web:xxxxxxxxxxxxxxxxxx"
VITE_FIREBASE_MEASUREMENT_ID="G-XXXXXXXXXX"

# ===== Cloudinary (current frontend flow) =====
# These power the unsigned upload widget in src/lib/cloudinary.ts.
# Do NOT put the Cloudinary API secret in the client .env file.
VITE_CLOUDINARY_CLOUD_NAME="your-cloud-name"
VITE_CLOUDINARY_UPLOAD_PRESET="your-unsigned-upload-preset"

# ===== Cloudinary (optional future signed uploads) =====
# Only needed if you move uploads to a backend endpoint/function.
# CLOUDINARY_API_KEY="your-api-key"
# CLOUDINARY_API_SECRET="your-api-secret"
# CLOUDINARY_CLOUD_NAME="your-cloud-name"

# ===== Razorpay (Phase 4) =====
# NOT needed client-side anymore — the Razorpay key ID is returned by the
# createRazorpayOrder Cloud Function per-request, and the secret key never
# touches the client. Set the real secrets on the FUNCTIONS side instead:
#   firebase functions:secrets:set RAZORPAY_KEY_ID
#   firebase functions:secrets:set RAZORPAY_KEY_SECRET
#   firebase functions:secrets:set RAZORPAY_WEBHOOK_SECRET
# (see functions/.env.example for local emulator testing)

# ===== Existing (unrelated to backend build) =====
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"
